{
  "format_version": "1.20.81",
  "animation_controllers": {
    "controller.animation.item.vodka": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {"using": "q.is_using_item"}
          ]
        },
        "using": {
          "animations": ["use"],
          "transitions": [
            {"default": "q.all_animations_finished"},
            {"default": "!q.equipped_item_any_tag('slot.weapon.mainhand', 'vodka')"}
          ]
        }
      }
    },
    "controller.animation.vodka": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {"hold": "v.vodka"}
          ]
        },
        "hold": {
          "animations": [
            {"first_person_empty_hand": "v.is_first_person"}
          ],
          "transitions": [
            {"using": "q.is_using_item"},
            {"default": "!v.vodka"}
          ]
        },
        "using": {
          "animations": [
            {"vodka_using": "v.is_first_person"}
          ],
          "transitions": [
            {"hold": "q.all_animations_finished"},
            {"default": "!v.vodka"}
          ]
        }
      }
    }
  }
}