{
	"format_version": "1.20.50",
	"animation_controllers": {
		"controller.animation.vodka": {
			"initial_state": "default",
			"states": {
				"default": {
          "transitions": [
            { "draw": "v.vodka" }
          ]
        },
				"draw": {
					"animations": [
            "vodka_hold",
            "vodka_draw"
          ],
					"transitions": [
            { "hold": "q.all_animations_finished" }
          ],
					"blend_transition": 0.1,
					"blend_via_shortest_path": true
				},
				"hold": {
					"animations": [
            "vodka_hold"
          ],
					"transitions": [
						{ "using": "q.is_using_item" },
						{ "default": "!v.vodka" }
					],
					"blend_transition": 0.1,
					"blend_via_shortest_path": true
				},
				"using": {
					"animations": [
            "vodka_using"
          ],
					"transitions": [
						{ "draw": "q.all_animations_finished" },
						{ "default": "!v.vodka" }
					],
					"blend_transition": 0.1,
					"blend_via_shortest_path": true
				}
			}
		}
	}
}
