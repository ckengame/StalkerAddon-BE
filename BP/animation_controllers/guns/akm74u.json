{
	"format_version": "1.20.80",
	"animation_controllers": {
		"controller.animation.akm74u": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{"draw": "q.is_item_name_any('slot.weapon.mainhand', 'scm:akm74u')"}
					]
				},
				"draw": {
					"on_entry": [
						"v.timer = q.life_time;",
						"/camerashake add @s 0.056 0.5833 positional",
						"/playsound generic_draw @s"
					],
					"on_exit": [
						"/camerashake stop @s",
						"/stopsound @s generic_draw"
					],
					"transitions": [
						{ "default": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:akm74u')" },
						{ "hold": "(q.life_time - v.timer) >= 0.5833" }
					]
				},
				"hold": {
					"transitions": [
						{ "default": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:akm74u')" },
						{ "reload": "!q.is_sprinting && q.is_using_item && q.scoreboard('akm74u') == 0" },
						{ "shoot": "!q.is_sprinting && q.is_using_item && q.scoreboard('akm74u') > 0" }
					]
				},


				"reload": {
					"on_entry": [
						"/event entity @s[hasitem={item=scm:ammo_5_45x39mm, quantity=1..}] gun:reload"
					],
					"transitions": [
						{ "reload_start": "q.mark_variant == 2" },
						{ "hold": "q.mark_variant != 2" }
					]
				},
				"reload_start": {
					"on_entry": [
						"v.timer = q.life_time;",
						"/playsound akm74u.reload @s",
						"/camerashake add @s 0.065 1.5417 positional"
					],
					"transitions": [
						{"reload_great": "(q.life_time - v.timer) >= 1.5417"},
						{"reload_error": "q.is_sprinting || !q.is_item_name_any('slot.weapon.mainhand', 'scm:akm74u')"}
					]
				},
				"reload_great": {
					"on_entry": [
						"@s gun:base",
						"/execute as @s[hasitem={item=scm:ammo_5_45x39mm, quantity=1..}] run function reload/akm74u"
					],
					"transitions": [
						{"hold": "(1.0)"}
					]
				},
				"reload_error": {
					"on_entry": [
						"@s gun:base",
						"/stopsound @s akm74u.reload",
						"/camerashake stop @s"
					],
					"transitions": [
						{"default": "(1.0)"}
					]
				},


				"shoot": {
					"on_entry": [
						"v.timer = q.life_time;",
						"@s gun:shoot",
						"@s ambullet:akm74u",
						"/playsound akm74u.shoot @s[r=200]",
						"/camerashake add @s 0.15 0.1 rotational",
						"/scoreboard players remove @s akm74u 1"
					],
					"transitions": [
						{ "default": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:akm74u')" },
						{ "hold": "(q.life_time - v.timer) >= 0.09" }
					]
				}
			}
		}
	}
}