{
	"format_version": "1.20.80",
	"animation_controllers": {
		"controller.animation.colt": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{"draw": "q.is_item_name_any('slot.weapon.mainhand', 'scm:colt')"}
					]
				},
				"draw": {
					"on_entry": [
						"v.timer = q.life_time;",
						"/camerashake add @s 0.056 0.5833 positional",
						"/playsound generic_draw @s"
					],
					"on_exit": [
						"/camerashake stop @s",
						"/stopsound @s generic_draw"
					],
					"transitions": [
						{ "default": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:colt')" },
						{ "hold": "(q.life_time - v.timer) >= 0.5833" }
					]
				},
				"hold": {
					"transitions": [
						{ "default": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:colt')" },
						{ "reload": "!q.is_sprinting && q.is_using_item && q.scoreboard('colt') == 0" },
						{ "shoot": "!q.is_sprinting && q.is_using_item && q.scoreboard('colt') > 0" }
					]
				},


				"reload": {
					"on_entry": [
						"/event entity @s[hasitem={item=scm:ammo_45acp, quantity=1..}] gun:reload"
					],
					"transitions": [
						{ "reload_start": "q.mark_variant == 2" },
						{ "hold": "q.mark_variant != 2" }
					]
				},
				"reload_start": {
					"on_entry": [
						"v.timer = q.life_time;",
						"/playsound colt.reload @s",
						"/camerashake add @s 0.065 1.875 positional"
					],
					"transitions": [
						{"reload_great": "(q.life_time - v.timer) >= 1.875"},
						{"reload_error": "q.is_sprinting || !q.is_item_name_any('slot.weapon.mainhand', 'scm:colt')"}
					]
				},
				"reload_great": {
					"on_entry": [
						"@s gun:base",
						"/execute as @s[hasitem={item=scm:ammo_45acp, quantity=1..}] run function wpn/colt_reload"
					],
					"transitions": [
						{"hold": "(1.0)"}
					]
				},
				"reload_error": {
					"on_entry": [
						"@s gun:base",
						"/stopsound @s colt.reload",
						"/camerashake stop @s"
					],
					"transitions": [
						{"default": "(1.0)"}
					]
				},


				"shoot": {
					"on_entry": [
						"v.timer = q.life_time;",
						"@s gun:shoot",
						"@s ambullet:colt",
						"/playsound colt.shoot @a[r=200] ~~~",
						"/camerashake add @s 0.1 0.2 rotational",
						"/scoreboard players remove @s colt 1"
					],
					"transitions": [
						{ "default": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:colt')" },
						{ "hold": "(q.life_time - v.timer) >= 0.2" }
					]
				}
			}
		}
	}
}