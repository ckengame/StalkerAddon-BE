{
	"format_version": "1.20.80",
	"animation_controllers": {
		"controller.animation.fort": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"draw": "q.is_item_name_any('slot.weapon.mainhand', 'scm:fort')"
						}
					]
				},
				"draw": {
					"on_entry": [
						"v.timer = q.life_time;",
						"/camerashake add @s 0.056 0.4167 positional",
						"/playsound generic_draw @s"
					],
					"on_exit": [
						"/camerashake stop @s",
						"/stopsound @s generic_draw"
					],
					"transitions": [
						{
							"default": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:fort')"
						},
						{
							"hold": "(q.life_time - v.timer) >= 0.4167"
						}
					]
				},
				"hold": {
					"transitions": [
						{
							"default": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:fort')"
						},
						{
							"reload": "!q.is_sprinting && q.is_using_item && q.scoreboard('fort') == 0"
						},
						{
							"shoot": "!q.is_sprinting && q.is_using_item && q.scoreboard('fort') > 0"
						}
					]
				},
				"reload": {
					"on_entry": [
						"/event entity @s[hasitem={item=scm:ammo_9x18mm, quantity=1..}] gun:reload"
					],
					"transitions": [
						{
							"reload_start": "q.mark_variant == 2"
						},
						{
							"hold": "q.mark_variant != 2"
						}
					]
				},
				"reload_start": {
					"on_entry": [
						"v.timer = q.life_time;",
						"/playsound fort.reload @s",
						"/camerashake add @s 0.065 2.2083 positional"
					],
					"transitions": [
						{
							"reload_great": "(q.life_time - v.timer) >= 2.2083"
						},
						{
							"reload_error": "q.is_sprinting || !q.is_item_name_any('slot.weapon.mainhand', 'scm:fort')"
						}
					]
				},
				"reload_great": {
					"on_entry": [
						"@s gun:base",
						"/execute as @s[hasitem={item=scm:ammo_9x18mm, quantity=1..}] run function wpn/fort_reload"
					],
					"transitions": [
						{
							"hold": "(1.0)"
						}
					]
				},
				"reload_error": {
					"on_entry": [
						"@s gun:base",
						"/stopsound @s fort.reload",
						"/camerashake stop @s"
					],
					"transitions": [
						{
							"default": "(1.0)"
						}
					]
				},
				"shoot": {
					"on_entry": [
						"v.timer = q.life_time;",
						"@s gun:shoot",
						"@s ambullet:fort",
						"/playsound fort.shoot @a[r=200] ~~~",
						"/camerashake add @s 0.15 0.1 rotational",
						"/scoreboard players remove @s fort 1"
					],
					"transitions": [
						{
							"default": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:fort')"
						},
						{
							"hold": "(q.life_time - v.timer) >= 0.16"
						}
					]
				}
			}
		}
	}
}