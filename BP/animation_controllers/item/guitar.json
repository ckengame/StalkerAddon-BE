{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.guitar": {
			"states": {
				"default": {
					"transitions": [
						{
							"walking": "!q.is_item_name_any('slot.weapon.mainhand', 'scm:guitar')"
						}
					]
				},
				"walking": {
					"transitions": [
						{
							"default": "q.is_item_name_any('slot.weapon.mainhand', 'scm:guitar')"
						}
					],
					"on_entry": [
						"/stopsound @s cken.guitar"
					]
				}
			}
		}
	}
}