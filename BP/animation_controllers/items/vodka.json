{
	"format_version": "1.10.0",
	"animation_controllers": {
		"controller.animation.vodka": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{ "using": "q.scoreboard('vodka')<=0 && q.is_item_name_any('slot.weapon.mainhand', 'ckendrink:vodka') && q.is_using_item" },
						{ "completion": "q.scoreboard('vodka')==1 && q.is_item_name_any('slot.weapon.mainhand', 'ckendrink:vodka')" },
						{ "stop": "q.scoreboard('vodka')>=1 && !q.is_item_name_any('slot.weapon.mainhand', 'ckendrink:vodka')" }
					]
				},
				"using": {
					"transitions": [ { "default": "(1.0)" } ],
					"on_entry": [
						"/scoreboard players set @s vodka 140",
						"/playsound item.vodka_drink_last @s",
						"/playanimation @s animation.vodka.use.fp"
					]
				},
				"completion": {
					"transitions": [ { "default": "(1.0)" } ],
					"on_entry": [
						"/clear @s ckendrink:vodka 0 1"
					]
				},
				"stop": {
					"transitions": [ { "default": "(1.0)" } ],
					"on_entry": [
						"/stopsound @s item.vodka_drink_last",
						"/playanimation @s animation.player.first_person.base_pose",
						"/scoreboard players set @s vodka 0"
					]
				}
			}
		}
	}
}