{
	"format_version": "1.20.81",
	"animation_controllers": {
		"controller.animation.revolver": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{ "shoot": "q.is_item_name_any('slot.weapon.mainhand', 0, 'mlg:revolver') && q.is_using_item && q.scoreboard('revolver') > 0" }
					]
				},
				"shoot": {
					"on_entry": [
						"@s mlg:revolver",
						"/playsound revolver.shoot @s ~ ~ ~ 1"
					],
					"transitions": [{ "default": "1.0" }]
				}
			}
		}
	}
}
