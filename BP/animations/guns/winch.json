{
	"format_version": "1.10.0",
	"animations": {
		"animation.player.winch_shoot": {
			"animation_length": 0.91,
			"timeline": {
				"0.0": [
					"/playsound winch.shoot @s[r=200]",
					"/camerashake add @s 0.1 0.2 rotational",
					"/scoreboard players remove @s winch 1",
					"@s ambullet:winch"
				]
			}
		},
		"animation.player.winch_reload": {
			"animation_length": 3.00,
			"timeline": {
				"0.0": [
					"/event entity @s[hasitem={item=scm:ammo_12x70, quantity=1..}] gun:reload"
				],
				"2.85": [
					"/scoreboard players set @s[hasitem={item=scm:ammo_12x70, quantity=1}] winch 1",
					"/scoreboard players set @s[hasitem={item=scm:ammo_12x70, quantity=2}] winch 2",
					"/scoreboard players set @s[hasitem={item=scm:ammo_12x70, quantity=3}] winch 3",
					"/scoreboard players set @s[hasitem={item=scm:ammo_12x70, quantity=4}] winch 4",
					"/scoreboard players set @s[hasitem={item=scm:ammo_12x70, quantity=5}] winch 5",
					"/scoreboard players set @s[hasitem={item=scm:ammo_12x70, quantity=6}] winch 6",
					"/scoreboard players set @s[hasitem={item=scm:ammo_12x70, quantity=7..}] winch 7",

					"/clear @s[hasitem={item=scm:ammo_12x70, quantity=1}] scm:ammo_12x70 0 1",
					"/clear @s[hasitem={item=scm:ammo_12x70, quantity=2}] scm:ammo_12x70 0 2",
					"/clear @s[hasitem={item=scm:ammo_12x70, quantity=3}] scm:ammo_12x70 0 3",
					"/clear @s[hasitem={item=scm:ammo_12x70, quantity=4}] scm:ammo_12x70 0 4",
					"/clear @s[hasitem={item=scm:ammo_12x70, quantity=5}] scm:ammo_12x70 0 5",
					"/clear @s[hasitem={item=scm:ammo_12x70, quantity=6}] scm:ammo_12x70 0 6",
					"/clear @s[hasitem={item=scm:ammo_12x70, quantity=7..}] scm:ammo_12x70 0 7"
				]
			}
		}
	}
}