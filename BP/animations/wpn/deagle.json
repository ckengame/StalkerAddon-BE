{
	"format_version": "1.10.0",
	"animations": {
		"animation.player.deagle_shoot": {
			"animation_length": 0.2,
			"timeline": {
				"0.0": [
					"/playsound deagle.shoot @s[r=200]",
					"/camerashake add @s 0.1 0.2 rotational",
					"/scoreboard players remove @s deagle 1",
					"@s ambullet:deagle"
				]
			}
		},
		"animation.player.deagle_reload": {
			"animation_length": 2,
			"timeline": {
				"0.0": [
					"/event entity @s[hasitem={item=scm:ammo_45acp, quantity=1..}] gun:reload"
				],
				"1.99": [
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=1}] deagle 1",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=2}] deagle 2",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=3}] deagle 3",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=4}] deagle 4",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=5}] deagle 5",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=6}] deagle 6",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=7}] deagle 7",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=8..}] deagle 8",

					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=1}] scm:ammo_45acp 0 1",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=2}] scm:ammo_45acp 0 2",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=3}] scm:ammo_45acp 0 3",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=4}] scm:ammo_45acp 0 4",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=5}] scm:ammo_45acp 0 5",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=6}] scm:ammo_45acp 0 6",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=7}] scm:ammo_45acp 0 7",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=8..}] scm:ammo_45acp 0 8"
				]
			}
		}
	}
}