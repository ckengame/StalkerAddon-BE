{
	"format_version": "1.10.0",
	"animations": {
		"animation.player.hpsa_shoot": {
			"animation_length": 0.2,
			"timeline": {
				"0.0": [
					"/playsound hpsa.shoot @s[r=200]",
					"/camerashake add @s 0.1 0.2 rotational",
					"/scoreboard players remove @s hpsa 1",
					"@s ambullet:hpsa"
				]
			}
		},
		"animation.player.hpsa_reload": {
			"animation_length": 2,
			"timeline": {
				"0.0": [
					"/event entity @s[hasitem={item=scm:ammo_9x19mm_fmj, quantity=1..}] gun:reload"
				],
				"1.99": [
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x19mm_fmj, quantity=1}] beretta 1",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x19mm_fmj, quantity=2}] beretta 2",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x19mm_fmj, quantity=3}] beretta 3",
