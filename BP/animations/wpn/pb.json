{
	"format_version": "1.10.0",
	"animations": {
		"animation.player.pb_shoot": {
			"animation_length": 0.2,
			"timeline": {
				"0.0": [
					"/playsound pb.shoot @s[r=200]",
					"/camerashake add @s 0.1 0.2 rotational",
					"/scoreboard players remove @s pb 1",
					"@s ambullet:pb"
				]
			}
		},
		"animation.player.pb_reload": {
			"animation_length": 2,
			"timeline": {
				"0.0": [
					"/event entity @s[hasitem={item=scm:ammo_9x18mm, quantity=1..}] gun:reload"
				],
				"1.99": [
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=1}] pb 1",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=2}] pb 2",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=3}] pb 3",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=4}] pb 4",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=5}] pb 5",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=6}] pb 6",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=7}] pb 7",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=8..}] pb 8",

					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=1}] scm:ammo_9x18mm 0 1",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=2}] scm:ammo_9x18mm 0 2",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=3}] scm:ammo_9x18mm 0 3",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=4}] scm:ammo_9x18mm 0 4",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=5}] scm:ammo_9x18mm 0 5",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=6}] scm:ammo_9x18mm 0 6",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=7}] scm:ammo_9x18mm 0 7",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=8..}] scm:ammo_9x18mm 0 8"
				]
			}
		}
	}
}