{
	"format_version": "1.10.0",
	"animations": {
		"animation.player.sig220_shoot": {
			"animation_length": 0.2,
			"timeline": {
				"0.0": [
					"/playsound sig220.shoot @s[r=200]",
					"/camerashake add @s 0.1 0.2 rotational",
					"/scoreboard players remove @s sig220 1",
					"@s ambullet:sig220"
				]
			}
		},
		"animation.player.sig220_reload": {
			"animation_length": 2,
			"timeline": {
				"0.0": [
					"/event entity @s[hasitem={item=scm:ammo_45acp, quantity=1..}] gun:reload"
				],
				"1.99": [
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=1}] sig220 1",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=2}] sig220 2",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=3}] sig220 3",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=4}] sig220 4",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=5}] sig220 5",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=6}] sig220 6",
					"/scoreboard players set @s[hasitem={item=scm:ammo_45acp,quantity=7..}] sig220 7",

					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=1}] scm:ammo_45acp 0 1",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=2}] scm:ammo_45acp 0 2",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=3}] scm:ammo_45acp 0 3",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=4}] scm:ammo_45acp 0 4",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=5}] scm:ammo_45acp 0 5",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=6}] scm:ammo_45acp 0 6",
					"/clear @s[hasitem={item=scm:ammo_45acp,quantity=7..}] scm:ammo_45acp 0 7"
				]
			}
		}
	}
}