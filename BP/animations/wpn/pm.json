{
	"format_version": "1.10.0",
	"animations": {
		"animation.player.pm_shoot": {
			"animation_length": 0.2,
			"timeline": {
				"0.0": [
					"/playsound pm.shoot @s[r=200]",
					"/camerashake add @s 0.1 0.2 rotational",
					"/scoreboard players remove @s pm 1",
					"@s ambullet:pm"
				]
			}
		},
		"animation.player.pm_reload": {
			"animation_length": 2,
			"timeline": {
				"0.0": [
					"/event entity @s[hasitem={item=scm:ammo_9x18mm, quantity=1..}] gun:reload"
				],
				"1.99": [
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=1}] pm 1",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=2}] pm 2",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=3}] pm 3",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=4}] pm 4",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=5}] pm 5",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=6}] pm 6",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=7}] pm 7",
					"/scoreboard players set @s[hasitem={item=scm:ammo_9x18mm, quantity=8..}] pm 8",

					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=1}] scm:ammo_9x18mm 0 1",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=2}] scm:ammo_9x18mm 0 2",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=3}] scm:ammo_9x18mm 0 3",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=4}] scm:ammo_9x18mm 0 4",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=5}] scm:ammo_9x18mm 0 5",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=6}] scm:ammo_9x18mm 0 6",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=7}] scm:ammo_9x18mm 0 7",
					"/clear @s[hasitem={item=scm:ammo_9x18mm, quantity=8..}] scm:ammo_9x18mm 0 8"
				]
			}
		}
	}
}